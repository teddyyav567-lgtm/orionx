            [
                InlineKeyboardButton("Passer en DEMO", callback_data="switch_account_DEMO"),
                InlineKeyboardButton("Passer en REAL", callback_data="switch_account_REAL")
            ]
        ]
        # InlineKeyboardMarkup arranges these buttons into a grid that will be attached to the message.
        reply_markup = InlineKeyboardMarkup(keyboard)

        return dashboard_text, reply_markup

    def toggle_trading(self):
        self.system_state["is_trading"] = not self.system_state["is_trading"]
        status = 'ACTIVÉ' if self.system_state["is_trading"] else 'DÉSACTIVÉ'
        self.stats['notification'] = f"⚙️ Trading {status}"
        self.logger.info(f"Action: Trading toggled to {status}")
        self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()

    def toggle_mode(self):
        self.system_state["is_real"] = not self.system_state["is_real"]
        mode = 'RÉEL' if self.system_state["is_real"] else 'DÉMO'
        self.system_state["current_mode"] = mode # Update current_mode in system_state as well
        self.stats['notification'] = f"🔄 Mode {mode}"
        self.logger.info(f"Action: Mode toggled to {mode}")
        self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()

    def refresh_dashboard(self):
        self.stats['notification'] = "📊 Dashboard Actualisé"
        self.logger.info("Action: Dashboard refreshed")

    def refresh_ai_brain(self):
        self.stats['notification'] = "🧠 Cerveau IA Actualisé"
        self.logger.info("Action: AI brain refreshed (conceptual)")
        # In a real scenario, this might involve re-initializing the AI context.
        # For example: asyncio.create_task(self.chat_with_sentinel("RESET_CONTEXT"))
        self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()

    async def _start(self, update: telegram.Update, context: ContextTypes.DEFAULT_TYPE):
        # Send or refresh the dashboard when the /start or /dashboard command is used.
        await self.update_dashboard_telegram()
        if update.message:
            await update.message.reply_text("✅ OrionX dashboard initialisé. Utilisez les boutons ci-dessous pour interagir.")

    def increase_lot(self, step=0.01):
        new_lot = round(self.current_lot + step, 2)
        if new_lot <= Config.MAX_LOT_SIZE:
            self.current_lot = new_lot
            self.stats['notification'] = f"➕ Lot augmenté à {self.current_lot}"
            self.logger.info(f"Action: Lot increased to {self.current_lot}")
        else:
            self.stats['notification'] = f"⚠️ Lot Max ({Config.MAX_LOT_SIZE}) atteint"
            self.logger.warning(f"Action: Attempted to increase lot beyond max ({Config.MAX_LOT_SIZE}). Current lot: {self.current_lot}")

    def decrease_lot(self, step=0.01):
        new_lot = round(self.current_lot - step, 2)
        if new_lot >= 0.01: # Minimum lot size
            self.current_lot = new_lot
            self.stats['notification'] = f"➖ Lot diminué à {self.current_lot}"
            self.logger.info(f"Action: Lot decreased to {self.current_lot}")
        else:
            self.stats['notification'] = "⚠️ Lot Min (0.01) atteint"
            self.logger.warning(f"Action: Attempted to decrease lot below min (0.01). Current lot: {self.current_lot}")

    def _check_internet_connection(self):
        if self._simulate_internet_cut:
            return False
        try:
            socket.create_connection(("8.8.8.8", 53), timeout=5)
            return True
        except OSError:
            return False

    def simulate_internet_cut(self, cut: bool):
        self._simulate_internet_cut = cut
        status = "ACTIVÉE" if cut else "DÉSACTIVÉE"
        self.logger.info(f"Action: Simulation de coupure internet {status}")
        self.stats['notification'] = f"📡 Coupure Internet Sim. {status}"

    def switch_account(self, account_type: str):
        if not self._check_internet_connection():
            self.stats['notification'] = "❌ NO INTERNET"
            self.logger.warning("Switch account failed: No internet connection.")
            return False

        if account_type not in ACCOUNT_CONFIG:
            self.stats['notification'] = f"❌ Compte '{account_type}' inconnu"
            self.logger.error(f"Invalid account type attempted: {account_type}")
            return False

        account_info = ACCOUNT_CONFIG[account_type]
        login = account_info['login']
        password = account_info['password']
        server = account_info['server']

        if mt5:
            # Shutdown current connection if any
            if self.system_state["mt5_online"]:
                mt5.shutdown()
                self.system_state["mt5_online"] = False

            # Initialize new connection
            mt5_init_success = mt5.initialize()
            self.system_state["mt5_online"] = mt5_init_success

            if not mt5_init_success:
                self.stats['notification'] = "❌ MT5 Init failed"
                self.logger.error(f"MT5 initialization failed for {account_type} account.")
                return False

            # Login to the new account
            authorized = mt5.login(login, password=password, server=server)
            if not authorized:
                self.stats['notification'] = "❌ MT5 Login failed"
                self.logger.error(f"MT5 login failed for {account_type} account: {mt5.last_error()}")
                mt5.shutdown()
                self.system_state["mt5_online"] = False # Ensure MT5 is marked offline on login failure
                return False

            self.system_state["mt5_online"] = True
            self.system_state["current_mode"] = account_type
            self.system_state["is_real"] = (account_type == "REAL")
            self.stats['notification'] = f"✅ Connecté {account_type}"
            self.logger.info(f"Successfully switched to {account_type} account (Login: {login}).")
            self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()
            return True
        else:
            self.stats['notification'] = "❌ MT5 non disponible"
            self.logger.error("MetaTrader5 module not imported. Cannot switch accounts.")
            return False

    async def _send_or_edit_telegram_message(self, text, reply_markup=None):

        if not self.telegram_bot or not Config.TELEGRAM_CHAT_ID:
            return

        if self.telegram_dashboard_failures >= 3:
            self.logger.warning("Telegram dashboard disabled after repeated failures.")
            return

        try:
            if self.last_msg_id:
                await self.telegram_bot.edit_message_text(
                    chat_id=Config.TELEGRAM_CHAT_ID,
                    message_id=self.last_msg_id,
                    text=text,
                    parse_mode='HTML',
                    reply_markup=reply_markup
                )
            else:
                msg = await self.telegram_bot.send_message(
                    chat_id=Config.TELEGRAM_CHAT_ID,
                    text=text,
                    parse_mode='HTML',
                    reply_markup=reply_markup
                )
                self.last_msg_id = msg.message_id

            self.telegram_dashboard_failures = 0
            self.logger.info("Telegram dashboard updated successfully.")

        except Exception as e:
            self.telegram_dashboard_failures += 1
            self.logger.error(f"Telegram error: {e}")
            if self.last_msg_id and "message to edit not found" in str(e).lower():
                self.last_msg_id = None
                self.logger.warning("Ancien message introuvable : le dashboard sera renvoyé une seule fois.")
            if self.last_msg_id is None and self.telegram_dashboard_failures >= 3:
                self.logger.error("Arrêt des nouvelles tentatives Telegram après 3 erreurs.")

    async def update_dashboard_telegram(self):
        current_time = time.time()
        if (current_time - self.last_dashboard_telegram_update) < self.DASHBOARD_UPDATE_INTERVAL:
            return # Skip update if too soon

        dashboard_text, reply_markup = self.build_dashboard()
        await self._send_or_edit_telegram_message(dashboard_text, reply_markup)
        self.last_dashboard_telegram_update = current_time

    def _reconnect_mt5(self):
        """Attempts to reconnect to MetaTrader5."""
        if mt5 and not self.system_state["mt5_online"]:
            self.logger.info("Attempting to reconnect to MT5...")
            if mt5.initialize():
                self.system_state["mt5_online"] = True
                self.stats['notification'] = "✅ MT5 Reconnected"
                self.logger.info("MT5 reconnected successfully.")
                self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()
            else:
                self.stats['notification'] = "❌ MT5 Reconnect failed"
                self.logger.error(f"Failed to reconnect MT5: {mt5.last_error()}")

    async def safe_ai_call(self, messages):
        await asyncio.sleep(max(0, self.ai_min_interval - (time.time() - self.ai_last_call)))

        try:
            response = await asyncio.to_thread(
                self.client_ai.chat.completions.create,
                model="gpt-4.1-mini", # Changed model as requested
                messages=messages
            )
            self.ai_last_call = time.time()
            self.stats["ai_calls"] += 1
            self.system_state["ai_online"] = True # Mark AI as online on successful call
            self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()
            return response.choices[0].message.content

        except Exception as e:
            self.logger.error(f"AI error: {e}")
            self.system_state["ai_online"] = False # Mark AI as offline on error
            self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()
            return None

    async def chat_with_sentinel(self, user_message):
        if not self.client_ai: return "IA Désactivée"

        # 5. AI Cooldown
        if time.time() - self.last_ai_call < Config.AI_COOLDOWN_SECONDS: return "⏳ Cooldown IA actif..."

        self.last_ai_call = time.time()
        start = time.time()
        try:
            system_context = FINAL_ORIONX_PROMPT.format(
                equity=self.stats['equity'],
                drawdown=self.stats['drawdown'],
                profit_day=self.stats['profit_day'],
                profit_month=self.stats['profit_month'],
                mt5_connected=self.system_state["mt5_online"],
                is_trading=self.system_state["is_trading"],
                current_lot=self.current_lot,
                max_lot=self.ai_intel['max_lot'],
                vault=self.ai_intel['vault'],
                trading_pool=self.ai_intel['trading_pool'],
                max_risk=self.ai_intel['max_risk'],
                notification=self.stats['notification'],
                stability=self.stats['stability']
            )

            # 3. Load conversational history
            history = await self.load_history()
            messages = [
                {"role": "system", "content": system_context},
                *history,
                {"role": "user", "content": user_message}
            ]

            # Use the new safe_ai_call wrapper
            ai_response = await self.safe_ai_call(messages)
            if ai_response is None:
                raise Exception("AI call failed or returned no content.")

            self.ai_latency = time.time() - start

            validator = AIResponseValidator()
            valid = validator.validate(ai_response)

            # 6. Robust AI Confidence parsing
            confidence = 0
            match = re.search(r'CONFIDENCE\s*:\s*(\d+)', ai_response, re.IGNORECASE)
            if match:
                confidence = int(match.group(1))
            self.ai_confidence = confidence

            monitor = AIStabilityMonitor()
            status, safe = monitor.evaluate(valid, self.ai_latency, confidence, self.ai_failures)
            self.ai_status, self.ai_safe_to_trade = status, safe
            self.ai_failures = 0 if safe else self.ai_failures + 1

            self.system_state["ai_online"] = True # Confirm AI is online after successful operation
            self.system_state["last_signal"] = ai_response # Update last signal from AI
            self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()

            # 4. Save user and assistant messages to database
            await asyncio.to_thread(
                self.cursor.execute,
                "INSERT INTO conversation_messages (role, content, timestamp) VALUES (?, ?, ?)",
                ("user", user_message, datetime.now(timezone.utc).isoformat())
            )
            await asyncio.to_thread(
                self.cursor.execute,
                "INSERT INTO conversation_messages (role, content, timestamp) VALUES (?, ?, ?)",
                ("assistant", ai_response, datetime.now(timezone.utc).isoformat())
            )
            await asyncio.to_thread(self.conn.commit)

            return ai_response

        except asyncio.TimeoutError:
            self.ai_status = "🔴 TIMEOUT"
            self.logger.error("AI chat timed out after 20 seconds")
            self.system_state["ai_online"] = False # Mark AI as offline on timeout
            self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()
            return "Erreur: La requête AI a expiré."
        except Exception as e:
            self.ai_status = "🔴 ERROR"
            self.logger.error(f"AI chat error: {e}", exc_info=True)
            self.system_state["ai_online"] = False # Mark AI as offline on error
            self.system_state["last_update"] = datetime.now(timezone.utc).isoformat()
            return f"Erreur: {str(e)}"

    async def _handle_callback_query(self, update: telegram.Update, context: ContextTypes.DEFAULT_TYPE):
        query = update.callback_query
        # Provide simple click feedback to user
        try:
            await query.answer(text="Clic!")
        except Exception:
            pass
        data = query.data

        if data == "toggle_trading":
            self.toggle_trading()
        elif data == "toggle_mode":
            self.toggle_mode()
        elif data == "increase_lot":
            self.increase_lot()
        elif data == "decrease_lot":
            self.decrease_lot()
        elif data == "refresh_dashboard":
            self.refresh_dashboard()
        elif data == "refresh_ai_brain":
            self.refresh_ai_brain()
        elif data == "simulate_internet_on":
            self.simulate_internet_cut(True)
        elif data == "simulate_internet_off":
            self.simulate_internet_cut(False)
        elif data == "switch_account_DEMO":
            self.switch_account("DEMO")
        elif data == "switch_account_REAL":
            self.switch_account("REAL")

        # After handling, update the dashboard message to reflect changes and re-send the keyboard
        await self.update_dashboard_telegram()

    async def run(self):
        last_mt5_reconnect_attempt = 0
        # Start the Telegram bot's polling mechanism in a non-blocking way
        if Config.TELEGRAM_TOKEN and getattr(self, 'application', None):
            try:
                await self.application.initialize()
                await self.application.start()
                self.telegram_bot = self.application.bot
                if getattr(self.application, 'updater', None) is not None:
                    await self.application.updater.start_polling()
                self.logger.info("Telegram polling started.")
            except Exception as e:
                self.logger.error(f"Telegram start failed: {e}")
                self.telegram_bot = None

        while self.running:
            current_time = time.time()
            # Start trader loop alongside engine
            if getattr(self, 'trader', None):
                 asyncio.create_task(self.trader.start(self, interval=1.0))
            # MT5 reconnection logic
            if not self.system_state["mt5_online"] and (current_time - last_mt5_reconnect_attempt) >= Config.MT5_RECONNECT_INTERVAL:
                self._reconnect_mt5()
                last_mt5_reconnect_attempt = current_time

            # Telegram dashboard update logic
            if self.telegram_bot: # Only check if bot is initialized
                await self.update_dashboard_telegram() # Now called unconditionally (time check is inside the function)

            await asyncio.sleep(1) # Check every second

        # Stop the Telegram bot's polling mechanism when the bot stops running
        if self.telegram_bot:
            if getattr(self.application, 'updater', None) is not None:
                await self.application.updater.stop_polling()
            await self.application.stop()

class TestOrionXAdvancedSecurity(unittest.TestCase):
    def setUp(self):
        with patch('MetaTrader5.initialize', return_value=True):
            self.bot = OrionXMasterV18Gold()
            self.bot.system_state["current_mode"] = "DEMO" # Initialize system_state for test

    def test_internet_cut_during_switch(self):
        """Vérifie que le bot bloque le switch si internet est coupé"""
        print("\n--- Test: Coupure Internet pendant Switch ---")

        # Activer la coupure internet simulée
        self.bot.simulate_internet_cut(True)

        # Tenter de passer en REAL
        success = self.bot.switch_account("REAL")

        # Vérifications
        self.assertFalse(success, "Le switch aurait dû échouer sans internet")
        self.assertEqual(self.bot.stats['notification'], "❌ NO INTERNET")
        self.assertEqual(self.bot.system_state["current_mode"], "DEMO", "Le bot doit rester en DEMO")

        # Rétablir internet et vérifier que ça remarche
        self.bot.simulate_internet_cut(False)
        with patch('MetaTrader5.shutdown'), \
             patch('MetaTrader5.initialize', return_value=True), \
             patch('MetaTrader5.login', return_value=True), \
             patch('MetaTrader5.account_info', return_value=MagicMock(login=87654321)): \

            success = self.bot.switch_account("REAL")
            self.assertTrue(success, "Le switch devrait fonctionner une fois internet rétabli")
            print("✅ Sécurité Internet validée")

if __name__ == '__main__' and os.getenv('RUN_TESTS', '0') == '1':
    # Run unit tests only when explicitly requested via environment variable
    suite = unittest.TestLoader().loadTestsFromTestCase(TestOrionXAdvancedSecurity)
    unittest.TextTestRunner(verbosity=1).run(suite)
# =========================================================
# ORIONX PERMANENT SYSTEM MONITOR
# AUTO STATUS + AUTO RESTART + LIVE TERMINAL
# =========================================================

import asyncio
import traceback
import MetaTrader5 as mt5
from openai import OpenAI
import telegram
import time

# =========================================================
# SYSTEM CHECK
# =========================================================

class SystemMonitor:

    def __init__(self):

        self.mt5_ok = False
        self.telegram_ok = False
        self.ai_ok = False

    # =====================================================
    # MT5 CHECK
    # =====================================================

    def check_mt5(self):

        try:

            if mt5.initialize():

                account = mt5.account_info()

                print("\n==============================")
                print("✅ MT5 CONNECTED")

                if account:
                    print(f"💰 LOGIN: {account.login}")
                    print(f"🏦 SERVER: {account.server}")
                    print(f"💵 BALANCE: {account.balance}")

                self.mt5_ok = True

            else:

                print("\n==============================")
                print("❌ MT5 NOT CONNECTED")
                print(mt5.last_error())

                self.mt5_ok = False

        except Exception as e:

            print(f"❌ MT5 ERROR: {e}")

            self.mt5_ok = False

    # =====================================================
    # TELEGRAM CHECK
    # =====================================================

    async def check_telegram(self):

        try:

            bot = telegram.Bot(
                token=Config.TELEGRAM_TOKEN
            )

            me = await bot.get_me()

            print("\n==============================")
            print("✅ TELEGRAM CONNECTED")
            print(f"🤖 BOT: {me.username}")

            self.telegram_ok = True

        except Exception as e:

            print("\n==============================")
            print("❌ TELEGRAM ERROR")
            print(e)

            self.telegram_ok = False

    # =====================================================
    # OPENAI CHECK
    # =====================================================

    def check_openai(self):

        try:

            client = OpenAI(
                api_key=Config.OPENAI_KEY
            )

            models = client.models.list()

            print("\n==============================")
            print("✅ OPENAI CONNECTED")
            print("🧠 AI READY")

            self.ai_ok = True

        except Exception as e:

            print("\n==============================")
            print("❌ OPENAI ERROR")

            error_text = str(e)

            print(error_text)

            # ==========================================
            # NO MONEY / BILLING
            # ==========================================

            if "429" in error_text:

                print("💳 OPENAI BILLING REQUIRED")

            if "invalid_api_key" in error_text:

                print("🔑 INVALID API KEY")

            if "quota" in error_text.lower():

                print("⚠️ API QUOTA EXCEEDED")

            self.ai_ok = False

    # =====================================================
    # GLOBAL STATUS
    # =====================================================

    def global_status(self):

        print("\n")
        print("========================================")
        print("🚀 ORIONX SYSTEM STATUS")
        print("========================================")

        print(f"📡 MT5       : {'✅ ONLINE' if self.mt5_ok else '❌ OFFLINE'}")
        print(f"📨 TELEGRAM : {'✅ ONLINE' if self.telegram_ok else '❌ OFFLINE'}")
        print(f"🧠 OPENAI    : {'✅ ONLINE' if self.ai_ok else '❌ OFFLINE'}")

        print("========================================")

# =========================================================
# AUTO RESTART LOOP
# =========================================================

async def permanent_launcher():

    monitor = SystemMonitor()

    while True:

        try:

            print("\n\n")
            print("========================================")
            print("🚀 STARTING ORIONX SYSTEM")
            print("========================================")

            # ======================================
            # CHECK SYSTEMS
            # ======================================

            monitor.check_mt5()

            await monitor.check_telegram()

            monitor.check_openai()

            monitor.global_status()

            # ======================================
            # START ENGINE
            # ======================================
            print("\n🔥 STARTING TRADING ENGINE...")
            print("📊 MARKET SCANNER ACTIVE")
            print("⚡ ULTRA FAST MODE ACTIVE")
            print("🧠 AI DECISION ENGINE ACTIVE")
            print("📡 LIVE MONITOR ACTIVE")
            print("💎 SYSTEM RUNNING")

            # ======================================
            # MAIN BOT LOOP
            # ======================================

            while True:

                try:

                    print("\n--------------------------------")

                    current_time = time.strftime("%H:%M:%S")

                    print(f"🕒 {current_time}")

                    # ==============================
                    # LIVE STATUS
                    # ==============================

                    if monitor.mt5_ok:
                        print("✅ MT5 ACTIVE")
                    else:
                        print("❌ MT5 DOWN")

                    if monitor.telegram_ok:
                        print("✅ TELEGRAM ACTIVE")
                    else:
                        print("❌ TELEGRAM DOWN")

                    if monitor.ai_ok:
                        print("✅ AI ACTIVE")
                    else:
                        print("❌ AI OFFLINE")

                    print("🔍 SCANNING MARKET...")
                    print("📈 ANALYZING MOMENTUM...")
                    print("🧠 AI ANALYZING...")
                    print("⚡ WAITING FOR SNIPER ENTRY...")

                    # ==============================
                    # HERE YOUR ENGINE RUNS
                    # ==============================

                    # symbol, direction, score = engine.ultra_scan_market()

                    await asyncio.sleep(3)

                except Exception as e:

                    print("\n❌ ENGINE ERROR")
                    print(e)

                    traceback.print_exc()

                    print("♻️ ENGINE RESTARTING...")

                    await asyncio.sleep(5)

        except Exception as e:

            print("\n❌ CRITICAL SYSTEM ERROR")
            print(e)

            traceback.print_exc()

            print("♻️ FULL SYSTEM RESTARTING...")

            await asyncio.sleep(10)

# =========================================================
# START SYSTEM
# =========================================================

if __name__ == "__main__":
    print("\nLaunching OrionX System...")

    bot = OrionXMasterV18Gold()
    asyncio.run(bot.run())
