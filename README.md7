class JsonFormatter(logging.Formatter):
    def format(self, record):
        log_record = {
            "timestamp": datetime.fromtimestamp(record.created, tz=timezone.utc).isoformat(),
            "level": record.levelname,
            "message": record.getMessage(),
            "name": record.name,
            "lineno": record.lineno,
            "pathname": record.pathname
        }
        if hasattr(record, 'extra_data'):
            log_record.update(record.extra_data)
        return json.dumps(log_record)

class AIResponseValidator:
    def validate(self, response_text):
        # Dummy validation for now
        return True

class AIStabilityMonitor:
    def evaluate(self, is_valid, latency, confidence, failures):
        # Dummy stability evaluation for now
        return "ONLINE" if is_valid else "OFFLINE", is_valid

class OrionXMasterV18Gold:
    def __init__(self):
        handler = logging.StreamHandler()
        handler.setFormatter(JsonFormatter())
        self.logger = logging.getLogger("OrionX_V18")
        self.logger.setLevel(logging.INFO)
        self.logger.addHandler(handler)
        self.logger.propagate = False
    def receive_trade_command(self, command: str):
        cmd = command.strip().lower()
        if cmd in ('buy','long'):
            self.trader.open_trade(1)
        elif cmd in ('sell','short'):
             self.trader.open_trade(-1)
        elif cmd == 'close_all':
              self.trader.close_all()
        elif cmd == 'pause':
             self.trader.robot_pause = True
        elif cmd == 'resume':
             self.trader.robot_pause = False
        else:
            print(f"Unknown trade command: {command}") 
        self.running = True
        self.current_lot = 0.01
        self.start_time = datetime.now(timezone.utc)
        self.peak_equity = 0.0
        self.last_msg_id = None
        self.telegram_dashboard_failures = 0
        # self.stats, self.ai_intel, and self.system_state together form the 'central memory'
        # that the dashboard reads from, as described in the user's explanation.
        self.stats = {'vault': 0.0, 'profit_day': 0.0, 'profit_month': 0.0, 'equity': 0.0, 'drawdown': 0.0, 'notification': "💎 SYSTÈME OPÉRATIONNEL", 'stability': 100.0, "ai_calls": 0}

        # Initialize system_state as the single source of truth
        # This acts as a part of the 'central memory' from which the dashboard reads.
        self.system_state = {
            "mt5_online": False,
            "ai_online": False,
            "engine_online": True, # Assuming the trading engine is logically online if the bot is running
            "is_trading": True,
            "is_real": False,
            "current_mode": "DEMO",
            "last_signal": None,
            "last_update": datetime.now(timezone.utc).isoformat()
        }

        self.ai_status = "OFFLINE"
        self.ai_safe_to_trade = False
        self.ai_latency = 0
        self.ai_confidence = 0
        self.ai_failures = 0
        self.ai_intel = {'motivation': "La discipline est la clé.", 'active_asset': "XAUUSD", 'current_strategy': "Scalping", 'signal_reason': "Analyse Sentiment", 'risk_level': "BAS", 'vault': 0.0, 'trading_pool': 0.0, 'max_risk': 0.0, 'max_lot': Config.MAX_LOT_SIZE}
        self.client_ai = OpenAI(api_key=Config.OPENAI_KEY) if Config.OPENAI_KEY else None
        self.last_ai_call = 0

        self.ai_request_queue = asyncio.Queue()
        self.ai_last_call = 0
        self.ai_min_interval = 1.5  # secondes entre requêtes

        self._simulate_internet_cut = False # Initialize simulation flag

        self.setup_database()
        if mt5:
            # Initialize MT5 if available
            mt5_init_success = mt5.initialize()
            self.system_state["mt5_online"] = mt5_init_success
            if mt5_init_success:
                self.logger.info("MT5 initialized successfully.")
            else:
                self.logger.error(f"Failed to initialize MT5: {mt5.last_error()}")
        # Create trading agent attached to master state
        self.trader = ORIONXTRADING(symbol=self.ai_intel.get('active_asset', 'EURUSD'))  
        # Update AI online status based on client availability
        self.system_state["ai_online"] = self.client_ai is not None
        
        # Initialize Telegram bot if token is provided
        if Config.TELEGRAM_TOKEN:
            try:
                self.application = ApplicationBuilder().token(Config.TELEGRAM_TOKEN).build()
                self.logger.info("Telegram bot initialized.")

                # Register handlers for the inline keyboard buttons
                self.application.add_handler(CallbackQueryHandler(self._handle_callback_query))
                self.application.add_handler(CommandHandler("start", self._start))
                self.application.add_handler(CommandHandler("dashboard", self._start))
            except Exception as e:
                self.logger.error(f"Failed to initialize Telegram application: {e}")
                self.application = None
                self.telegram_bot = None

        else:
            self.telegram_bot = None
            self.logger.warning("Telegram Token not found. Telegram features will be disabled.")

        self.DASHBOARD_UPDATE_INTERVAL = 10 # seconds
        self.last_dashboard_telegram_update = 0

    def setup_database(self):
        self.conn = sqlite3.connect(Config.CONVERSATION_DB, check_same_thread=False)
        self.cursor = self.conn.cursor()
        self.cursor.execute("CREATE TABLE IF NOT EXISTS conversation_messages (id INTEGER PRIMARY KEY AUTOINCREMENT, role TEXT, content TEXT, timestamp TEXT)")
        self.conn.commit()

    async def load_history(self):
        # Load conversation history from DB, limiting to MAX_CONVERSATION_HISTORY
        self.cursor.execute("SELECT role, content FROM conversation_messages ORDER BY timestamp DESC LIMIT ?", (Config.MAX_CONVERSATION_HISTORY,))
        history_data = self.cursor.fetchall()
        # History needs to be in chronological order for OpenAI API, so reverse it
        history = [{'role': row[0], 'content': row[1]} for row in reversed(history_data)]
        return history

    def build_dashboard(self):
        # As per the user's description, the dashboard reads information from a central state.
        # self.system_state, self.stats, and self.ai_intel collectively represent this state.
        # The dashboard's role is solely to display this information, not to generate it or interact directly with MT5.
        state = self.system_state # Use the centralized system state

        uptime = str(datetime.now(timezone.utc) - self.start_time).split('.')[0]
        mt_st = "🟢 LITE-LIVE" if state["mt5_online"] else "🔴 DÉCONNECTÉ"
        ai_st = "🟢 SENTINEL AI" if state["ai_online"] else "🔴 DÉSACTIVÉE"
        engine_st = "🟢 MOTEUR ACTIF" if state["engine_online"] else "🔴 MOTEUR INACTIF"

        goal_pct_daily = min(100, int((self.stats['profit_day'] / Config.DAILY_GOAL) * 100)) if Config.DAILY_GOAL > 0 else 0
        prog_daily = '█' * (goal_pct_daily // 10) + '░' * (10 - (goal_pct_daily // 10))
        goal_pct_monthly = min(100, int((self.stats['profit_month'] / Config.MONTHLY_GOAL) * 100)) if Config.MONTHLY_GOAL > 0 else 0
        prog_monthly = '█' * (goal_pct_monthly // 10) + '░' * (10 - (goal_pct_monthly // 10))

        dashboard_text = (
            f"<b>🏛 ORIONX TERMINAL - V18.5 GOLD ELITE</b>\n"
            f"🕒 <code>{datetime.now().strftime('%H:%M:%S')}</code> | 🤖 <code>Stab: {self.stats['stability']}%</code>\n"
            f"╠{'═'*38}╣\n"
            f"<b>╔═══════ 🧠 AI STATUS ENGINE ═══════╗</b>\n"
            f" 🧠 <b>STATUS:</b> <code>{self.ai_status}</code>\n"
            f" ⚡ <b>LATENCY:</b> <code>{self.ai_latency:.2f}s</code>\n"
            f" 🎯 <b>CONFIDENCE:</b> <code>{self.ai_confidence}%</code>\n"
            f" 🛡️ <b>AI SAFE:</b> <code>{'YES' if self.ai_safe_to_trade else 'NO'}</code>\n"
            f"<b>╚════════════════════════════════════╝</b>\n"
            f"╠{'═'*38}╣\n"
            f"📊 <b>GLOBAL PERFORMANCE</b> 📈\n"
            f" 💰 <b>Capital:</b> <code>{self.stats['equity']:.2f} USD</code>\n"
            f" 🏦 <b>Vault:</b> <code>{self.stats['vault']:.2f} USD</code>\n"
            f" 📉 <b>Drawdown:</b> <code>{self.stats['drawdown']:.2f}%</code>\n"
            f"╠{'═'*38}╣\n"
            f"🌟 <b>DAILY PERFORMANCE</b> 🌟\n"
